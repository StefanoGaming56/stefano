---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About">
  <main class="about">
    <h1>About</h1>
    <p>
      Welcome to the about page. This is an Astro SPA powered by View
      Transitions for seamless client-side navigation.
    </p>

    <section class="values">
      <h2>Our Values</h2>
      <div class="cards">
        <div class="card">
          <h3>Performance</h3>
          <p>Built with speed in mind. Minimal JavaScript, maximum efficiency.</p>
        </div>
        <div class="card">
          <h3>Simplicity</h3>
          <p>Clean architecture that's easy to understand and maintain.</p>
        </div>
        <div class="card">
          <h3>Modernity</h3>
          <p>Leveraging the latest web standards and best practices.</p>
        </div>
      </div>
    </section>

    <section class="tech">
      <h2>Tech Stack</h2>
      <ul>
        <li>Astro — Static site generation with island architecture</li>
        <li>View Transitions API — Native client-side routing</li>
        <li>TypeScript — Type-safe development</li>
      </ul>
    </section>
  </main>
</Layout>

<style>
  .about {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  p {
    line-height: 1.7;
    color: var(--color-text-muted, #555);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--color-surface, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 0.95rem;
    margin: 0;
  }

  ul {
    list-style: disc;
    padding-left: 1.5rem;
    line-height: 1.7;
    color: var(--color-text-muted, #555);
  }
</style>
