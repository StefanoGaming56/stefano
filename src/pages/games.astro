---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allGames = await getCollection("games");

const downloadableGames = allGames
    .filter((game) => game.data.platform !== "browser")
    .sort((a, b) => a.data.title.localeCompare(b.data.title));

const browserGames = allGames
    .filter((game) => game.data.platform === "browser")
    .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout title="Games - Stefano Gaming">
    <div class="games-page">
        <h1 class="page-title">Games</h1>

        <section class="section">
            <h2 class="section-title">Downloadable Games</h2>
            <div class="games-grid">
                {
                    downloadableGames.map((game) => (
                        <article class="game-card">
                            <div class="card-image-wrapper">
                                <img
                                    src={game.data.image}
                                    alt={game.data.title}
                                    class="card-image"
                                    loading="lazy"
                                />
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{game.data.title}</h3>
                                <a
                                    href={game.data.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="card-button"
                                >
                                    {game.data.platform === "itch"
                                        ? "Play on itch.io →"
                                        : "Download →"}
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="section">
            <h2 class="section-title">Old Website Games/Versions</h2>
            <p class="section-subtitle">
                (These can be played in your browser without any downloads, at
                the cost of quality)
            </p>
            <ul class="browser-games-list">
                {
                    browserGames.map((game, index) => (
                        <li class="browser-game-item">
                            <span class="game-number">{index + 1}.</span>
                            <a
                                href={game.data.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="browser-game-link"
                            >
                                {game.data.title}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </div>
</Layout>

<style>
    .games-page {
        --bg: #000000;
        --card-bg: #0a0a0a;
        --text: #ffffff;
        --muted: #818181;
        --primary: #fe2c00;
        --border: #222222;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 2rem;
        text-align: center;
    }

    .section {
        margin-bottom: 4rem;
    }

    .section-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.75rem;
    }

    .section-subtitle {
        color: var(--muted);
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .games-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    @media (max-width: 1024px) {
        .games-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .games-grid {
            grid-template-columns: 1fr;
        }
    }

    .game-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease,
            border-color 0.3s ease;
    }

    .game-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 32px rgba(254, 44, 0, 0.15);
        border-color: var(--primary);
    }

    .card-image-wrapper {
        width: 100%;
        height: 200px;
        overflow: hidden;
    }

    .card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease-out;
    }

    .card-content {
        padding: 1rem 1.25rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.4;
    }

    .card-button {
        display: inline-block;
        padding: 0.5rem 1rem;
        background-color: var(--primary);
        color: #fff;
        font-size: 0.875rem;
        font-weight: 600;
        border-radius: 6px;
        text-decoration: none;
        text-align: center;
        transition:
            background-color 0.2s ease,
            transform 0.2s ease;
    }

    .card-button:hover {
        background-color: #8a1800;
        color: #fff;
        transform: scale(1.03);
    }

    .card-button:active {
        transform: scale(0.98);
    }

    .browser-games-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .browser-game-item {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        transition:
            border-color 0.2s ease,
            background-color 0.2s ease;
    }

    .browser-game-item:hover {
        border-color: var(--primary);
        background-color: #0f0f0f;
    }

    .game-number {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 600;
        min-width: 1.75rem;
        flex-shrink: 0;
    }

    .browser-game-link {
        color: var(--primary);
        font-size: 0.95rem;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .browser-game-link:hover {
        color: #8a1800;
        text-decoration: underline;
    }

    @media (max-width: 640px) {
        .page-title {
            font-size: 2rem;
        }

        .section-title {
            font-size: 1.4rem;
        }
    }
</style>
