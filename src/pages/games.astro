---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allGames = await getCollection("games");

const downloadableGames = allGames
    .filter((game) => game.data.platform !== "browser")
    .sort((a, b) => a.data.title.localeCompare(b.data.title));

const browserGames = allGames
    .filter((game) => game.data.platform === "browser")
    .sort((a, b) => a.data.title.localeCompare(b.data.title));

const downloadableGamesJson = JSON.stringify(
    downloadableGames.map((game, index) => ({
        id: index,
        title: game.data.title,
        image: game.data.image,
        url: game.data.url,
        platform: game.data.platform,
    })),
);
---

<Layout title="Games - Stefano Gaming">
    <div class="games-page">
        <h1 class="page-title">Games</h1>

        <div class="toast" id="tutorial-toast" aria-live="polite">
            <div class="toast-content">
                <p class="toast-message">
                    First time here? Check out the
                    <a href="/download-tutorial" class="toast-link"
                        >Download Tutorial</a
                    >
                    for help getting started.
                </p>
                <button
                    class="toast-close"
                    id="toast-close"
                    aria-label="Dismiss"
                >
                    ×
                </button>
            </div>
        </div>

        <section class="section">
            <h2 class="section-title">Downloadable Games</h2>

            <div class="search-row">
                <div class="search-wrapper">
                    <svg
                        class="search-icon"
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input
                        type="text"
                        id="games-search"
                        class="search-input"
                        placeholder="Search games..."
                        autocomplete="off"
                    />
                </div>
                <a href="#browser-games" class="jump-button">
                    Jump to Old Web Games ↓
                </a>
            </div>

            <script
                type="application/json"
                id="games-data"
                set:html={downloadableGamesJson}
            />

            <div class="games-grid" id="downloadable-games-grid">
                {
                    downloadableGames.map((game, index) => (
                        <article
                            class="game-card"
                            data-game-index={index}
                            data-title={game.data.title.toLowerCase()}
                            style={index >= 18 ? "display:none" : undefined}
                        >
                            <div class="card-image-wrapper">
                                <img
                                    src={game.data.image}
                                    alt={game.data.title}
                                    class="card-image"
                                    loading="lazy"
                                />
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{game.data.title}</h3>
                                <a
                                    href={game.data.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="card-button"
                                >
                                    {game.data.platform === "itch"
                                        ? "Play on itch.io →"
                                        : "Download →"}
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>

            <div class="no-results" id="no-results" style="display: none;">
                <p>No games found matching your search.</p>
            </div>

            <div class="load-more-wrapper" id="load-more-wrapper">
                <button class="load-more-button" id="load-more-button">
                    Load More Games
                </button>
                <p class="games-count" id="games-count"></p>
            </div>
        </section>

        <section class="section" id="browser-games">
            <h2 class="section-title">Old Website Games/Versions</h2>
            <p class="section-subtitle">
                (These can be played in your browser without any downloads, at
                the cost of quality)
            </p>
            <ul class="browser-games-list">
                {
                    browserGames.map((game, index) => (
                        <li class="browser-game-item">
                            <span class="game-number">{index + 1}.</span>
                            <a
                                href={game.data.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="browser-game-link"
                            >
                                {game.data.title}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </div>

    <script>
        const GAMES_PER_PAGE = 18;

        function initGamesPage() {
            const dataEl = document.getElementById("games-data");
            if (!dataEl) return;

            const allGames = JSON.parse(dataEl.textContent || "[]");
            const grid = document.getElementById("downloadable-games-grid");
            const searchInput = document.getElementById("games-search");
            const loadMoreButton = document.getElementById("load-more-button");
            const loadMoreWrapper =
                document.getElementById("load-more-wrapper");
            const gamesCount = document.getElementById("games-count");
            const noResults = document.getElementById("no-results");

            if (
                !grid ||
                !searchInput ||
                !loadMoreButton ||
                !loadMoreWrapper ||
                !gamesCount ||
                !noResults
            )
                return;

            const cards = grid.querySelectorAll(".game-card");

            let visibleCount = GAMES_PER_PAGE;
            let currentSearchTerm = "";

            function getMatchingIndices(searchTerm) {
                if (!searchTerm) {
                    return allGames.map((_: any, i: number) => i);
                }
                const term = searchTerm.toLowerCase();
                return allGames
                    .map((game: any, i: number) => ({
                        title: game.title.toLowerCase(),
                        i,
                    }))
                    .filter((g: any) => g.title.includes(term))
                    .map((g: any) => g.i);
            }

            function render() {
                const matchingIndices = getMatchingIndices(currentSearchTerm);
                const isSearching = currentSearchTerm.length > 0;

                let visibleIndices;
                if (isSearching) {
                    visibleIndices = matchingIndices;
                } else {
                    visibleIndices = matchingIndices.slice(0, visibleCount);
                }

                cards.forEach((card, index) => {
                    const isMatch = matchingIndices.includes(index);
                    const isVisible = visibleIndices.includes(index);

                    if (isMatch && isVisible) {
                        card.style.display = "";
                    } else {
                        card.style.display = "none";
                    }
                });

                if (isSearching || matchingIndices.length <= visibleCount) {
                    loadMoreWrapper.style.display = "none";
                } else {
                    loadMoreWrapper.style.display = "flex";
                }

                const shown = isSearching
                    ? matchingIndices.length
                    : Math.min(visibleCount, matchingIndices.length);
                gamesCount.textContent = `Showing ${shown} of ${matchingIndices.length} games`;

                noResults.style.display =
                    matchingIndices.length === 0 ? "block" : "none";
            }

            // Remove old listeners by cloning elements
            const newSearchInput = searchInput.cloneNode(
                true,
            ) as HTMLInputElement;
            searchInput.parentNode?.replaceChild(newSearchInput, searchInput);

            const newLoadMoreButton = loadMoreButton.cloneNode(
                true,
            ) as HTMLButtonElement;
            loadMoreButton.parentNode?.replaceChild(
                newLoadMoreButton,
                loadMoreButton,
            );

            let debounceTimer: ReturnType<typeof setTimeout>;
            newSearchInput.addEventListener("input", (e) => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => {
                    currentSearchTerm = (
                        e.target as HTMLInputElement
                    ).value.trim();
                    visibleCount = GAMES_PER_PAGE;
                    render();
                }, 200);
            });

            newLoadMoreButton.addEventListener("click", () => {
                visibleCount += GAMES_PER_PAGE;
                render();
            });

            // Restore any search value that was in the input
            currentSearchTerm = newSearchInput.value.trim();

            render();
        }

        document.addEventListener("astro:page-load", initGamesPage);
        initGamesPage();

        function initTutorialToast() {
            const toast = document.getElementById("tutorial-toast");
            const closeBtn = document.getElementById("toast-close");
            if (!toast || !closeBtn) return;

            // Move toast to body so it escapes main's stacking context
            // and always renders above the footer
            document.body.appendChild(toast);

            const STORAGE_KEY = "stefano-games-toast-dismissed";

            if (!localStorage.getItem(STORAGE_KEY)) {
                requestAnimationFrame(() => {
                    toast.classList.add("toast--visible");
                });
            }

            const newCloseBtn = closeBtn.cloneNode(true) as HTMLButtonElement;
            closeBtn.parentNode?.replaceChild(newCloseBtn, closeBtn);

            newCloseBtn.addEventListener("click", () => {
                toast.classList.remove("toast--visible");
                localStorage.setItem(STORAGE_KEY, "true");
            });
        }

        document.addEventListener("astro:page-load", initTutorialToast);
        initTutorialToast();
    </script>
</Layout>

<style>
    .games-page {
        --bg: #000000;
        --card-bg: #0a0a0a;
        --text: #ffffff;
        --muted: #818181;
        --primary: #fe2c00;
        --border: #222222;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 2rem;
        text-align: center;
    }

    .section {
        margin-bottom: 4rem;
    }

    .section-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.75rem;
    }

    .jump-button {
        display: inline-block;
        padding: 0.4rem 1rem;
        background-color: transparent;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition:
            color 0.2s ease,
            border-color 0.2s ease;
    }

    .jump-button:hover {
        color: var(--primary);
        border-color: var(--primary);
    }

    .section-subtitle {
        color: var(--muted);
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    /* Search */
    .search-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .search-wrapper {
        position: relative;
        max-width: 400px;
        flex: 1;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 0.7rem 1rem 0.7rem 2.75rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        font-size: 0.95rem;
        outline: none;
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    .search-input::placeholder {
        color: var(--muted);
    }

    .search-input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(254, 44, 0, 0.15);
    }

    /* No results */
    .no-results {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--muted);
        font-size: 1rem;
    }

    /* Load more */
    .load-more-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        margin-top: 2rem;
    }

    .load-more-button {
        padding: 0.7rem 2rem;
        background-color: transparent;
        color: var(--primary);
        border: 2px solid var(--primary);
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            transform 0.2s ease;
    }

    .load-more-button:hover {
        background-color: var(--primary);
        color: #fff;
    }

    .load-more-button:active {
        transform: scale(0.97);
    }

    .games-count {
        color: var(--muted);
        font-size: 0.85rem;
    }

    /* Games grid */
    .games-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    @media (max-width: 1024px) {
        .games-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .games-grid {
            grid-template-columns: 1fr;
        }
    }

    .game-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease,
            border-color 0.3s ease;
    }

    .game-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 32px rgba(254, 44, 0, 0.15);
        border-color: var(--primary);
    }

    .card-image-wrapper {
        width: 100%;
        height: 200px;
        overflow: hidden;
    }

    .card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease-out;
    }

    .card-content {
        padding: 1rem 1.25rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.4;
    }

    .card-button {
        display: inline-block;
        padding: 0.5rem 1rem;
        background-color: var(--primary);
        color: #fff;
        font-size: 0.875rem;
        font-weight: 600;
        border-radius: 6px;
        text-decoration: none;
        text-align: center;
        transition:
            background-color 0.2s ease,
            transform 0.2s ease;
    }

    .card-button:hover {
        background-color: #8a1800;
        color: #fff;
        transform: scale(1.03);
    }

    .card-button:active {
        transform: scale(0.98);
    }

    /* Browser games */
    .browser-games-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .browser-game-item {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        transition:
            border-color 0.2s ease,
            background-color 0.2s ease;
    }

    .browser-game-item:hover {
        border-color: var(--primary);
        background-color: #0f0f0f;
    }

    .game-number {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 600;
        min-width: 1.75rem;
        flex-shrink: 0;
    }

    .browser-game-link {
        color: var(--primary);
        font-size: 0.95rem;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .browser-game-link:hover {
        color: #8a1800;
        text-decoration: underline;
    }

    /* Toast */
    .toast {
        --toast-bg: #1a1a1a;
        --toast-border: #fe2c00;
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        max-width: 560px;
        width: calc(100% - 2rem);
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
    }

    .toast--visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
    }

    .toast-content {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: var(--toast-bg);
        border: 1px solid var(--toast-border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
    }

    .toast-message {
        flex: 1;
        color: var(--text);
        font-size: 0.95rem;
        line-height: 1.5;
        margin: 0;
    }

    .toast-link {
        color: var(--primary);
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .toast-link:hover {
        color: #8a1800;
    }

    .toast-close {
        flex-shrink: 0;
        background: none;
        border: none;
        color: var(--muted);
        font-size: 1.5rem;
        line-height: 1;
        cursor: pointer;
        padding: 0 0.25rem;
        transition: color 0.2s ease;
    }

    .toast-close:hover {
        color: var(--text);
    }

    @media (max-width: 640px) {
        .page-title {
            font-size: 2rem;
        }

        .section-title {
            font-size: 1.4rem;
        }

        .search-wrapper {
            max-width: 100%;
        }

        .toast-content {
            padding: 0.85rem 1rem;
        }

        .toast-message {
            font-size: 0.9rem;
        }

        .toast {
            bottom: 1rem;
        }
    }
</style>
