---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const featuredGames = await getCollection(
    "games",
    (game) => game.data.featured,
);

const aboutEntries = await getCollection("about");
const about = aboutEntries[0];
const { Content } = await render(about);
---

<Layout title="Stefano Gaming" bodyClass="has-bg">
    <section class="hero">
        <img
            src="/images/name-banner.png"
            alt="Stefano Gaming"
            class="hero__banner"
        />
    </section>

    <section class="games">
        <div class="games__grid">
            {
                featuredGames.map((game) => (
                    <article
                        class="card"
                        data-has-video={!!game.data.youtubeId}
                    >
                        <div class="card__media">
                            <img
                                src={game.data.image}
                                alt={game.data.title}
                                class="card__media-img"
                            />
                            {game.data.youtubeId && (
                                <div
                                    class="card__media-video"
                                    data-src={`https://www.youtube.com/embed/${game.data.youtubeId}?autoplay=1&mute=1`}
                                >
                                    <iframe
                                        title={`${game.data.title} Trailer`}
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen
                                    />
                                </div>
                            )}
                        </div>
                        <h2 class="card__title">{game.data.title}</h2>
                        <a
                            href={game.data.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="card__link"
                        >
                            Play on itch.io
                        </a>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="about">
        <div class="about__container">
            <img src="/images/avatar.png" alt="Stefano" class="about__avatar" />
            <div class="about__content">
                <h2 class="about__title">{about.data.title}</h2>
                <Content />
            </div>
        </div>
    </section>

    <section class="callout">
        <div class="callout__container">
            <h2 class="callout__title">Want to see more?</h2>
            <p class="callout__text">
                Check out the full collection of games I've made.
            </p>
            <a href="/games" class="callout__button">Browse All Games</a>
        </div>
    </section>

    <div class="avatar-scroll-zone"></div>
</Layout>

<style is:global>
    body.has-bg {
        background-image: url("/images/background.jpg");
        background-size: cover;
        background-position: 50% 50%;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    body.has-bg::before {
        content: "";
        position: fixed;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.3) 0%,
            rgba(0, 0, 0, 0.6) 100%
        );
        z-index: 0;
        pointer-events: none;
    }

    body.has-bg main {
        position: relative;
        z-index: 1;
    }
</style>

<style>
    :root {
        --bg: #000000;
        --card-bg: #0a0a0a;
        --text: #ffffff;
        --muted: #818181;
        --primary: #fe2c00;
        --border: #222222;
    }

    .hero {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 4rem 1rem 3rem;
    }

    .hero__banner {
        max-width: 100%;
        height: auto;
    }

    .about {
        padding: 1.5rem 1.5rem 0;
    }

    .about__container {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        align-items: flex-start;
        gap: 2rem;
    }

    .about__avatar {
        width: 400px;
        height: auto;
        object-fit: cover;
        flex-shrink: 0;
        order: 2;
        transition: none;
    }

    .about__avatar--fixed {
        position: fixed;
        z-index: -1;
    }

    .about__title {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 1rem;
        color: var(--text);
    }

    .about__content {
        padding-top: 5rem;
    }

    .about__content p {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.7;
        margin: 0 0 0.75rem;
    }

    .about__content p:last-child {
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .about__container {
            flex-direction: column;
            text-align: center;
        }

        .about__avatar {
            display: none;
        }

        .about__content {
            padding-top: 0;
        }

        .avatar-scroll-zone {
            display: block;
            height: 60vh;
            background: url("/images/avatar.png") no-repeat center top;
            background-size: 200% auto;
        }
    }

    .callout {
        padding: 1.5rem 1.5rem 3rem;
        text-align: center;
    }

    .callout__container {
        max-width: 600px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        position: relative;
        z-index: 1;
    }

    .callout__title {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 0.75rem;
        color: var(--text);
    }

    .callout__text {
        color: var(--muted);
        font-size: 1rem;
        margin: 0 0 1.5rem;
        line-height: 1.6;
    }

    .callout__button {
        display: inline-block;
        padding: 0.75rem 2rem;
        background-color: var(--primary);
        color: var(--text);
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 1rem;
        transition: background-color 0.2s ease;
    }

    .callout__button:hover {
        background-color: #8a1800;
    }

    .avatar-scroll-zone {
        height: 75vh;
        position: relative;
    }

    .games {
        padding: 2rem 0;
    }

    .games__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .games__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .games__grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .card {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.2s ease;
    }

    .card:hover {
        border-color: var(--primary);
    }

    .card__media {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
    }

    .card__media-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition:
            opacity 0.3s ease,
            transform 0.4s ease-out;
    }

    .card__media-video {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .card__media-video iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    .card[data-has-video="true"]:hover .card__media-img {
        opacity: 0;
    }

    .card[data-has-video="true"]:hover .card__media-video {
        opacity: 1;
        pointer-events: auto;
    }

    .card__title {
        color: var(--text);
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1rem 1rem 0.75rem;
    }

    .card__link {
        display: inline-block;
        margin: 0 1rem 1rem;
        padding: 0.6rem 1.2rem;
        background-color: var(--primary);
        color: var(--text);
        text-decoration: none;
        border-radius: 4px;
        font-weight: 500;
        text-align: center;
        transition: background-color 0.2s ease;
    }

    .card__link:hover {
        background-color: #8a1800;
    }
</style>

<script>
    function initVideoOverlays() {
        document
            .querySelectorAll(".card[data-has-video='true']")
            .forEach((card) => {
                const videoDiv = card.querySelector(".card__media-video");
                if (!videoDiv) return;
                const iframe = videoDiv.querySelector("iframe");
                if (!iframe) return;

                card.addEventListener("mouseenter", () => {
                    iframe.src = videoDiv.dataset.src || "";
                });

                card.addEventListener("mouseleave", () => {
                    iframe.src = "";
                });
            });
    }

    function initAvatarSticky() {
        const avatar = document.querySelector(".about__avatar");
        const aboutSection = document.querySelector(".about");
        const scrollZone = document.querySelector(".avatar-scroll-zone");

        if (!avatar || !aboutSection) return;

        // Skip animation on mobile - CSS handles final state
        if (window.matchMedia("(max-width: 768px)").matches) return;

        const placeholder = document.createElement("div");
        let initialRect = null;

        function onScroll() {
            const aboutRect = aboutSection.getBoundingClientRect();

            // About section still visible - normal flow
            if (aboutRect.bottom >= window.innerHeight) {
                if (avatar.classList.contains("about__avatar--fixed")) {
                    avatar.classList.remove("about__avatar--fixed");
                    avatar.style.top = "";
                    avatar.style.left = "";
                    avatar.style.transform = "";
                    placeholder.remove();
                    initialRect = null;
                }
                return;
            }

            // Fix avatar when about section scrolls past
            if (!avatar.classList.contains("about__avatar--fixed")) {
                const avatarRect = avatar.getBoundingClientRect();
                initialRect = {
                    top: avatarRect.top,
                    left: avatarRect.left,
                    width: avatarRect.width,
                    height: avatarRect.height,
                };
                placeholder.style.width = avatarRect.width + "px";
                placeholder.style.height = avatarRect.height + "px";
                placeholder.style.order = "2";
                placeholder.style.flexShrink = "0";
                avatar.parentNode.insertBefore(placeholder, avatar);
                avatar.style.top = avatarRect.top + "px";
                avatar.style.left = avatarRect.left + "px";
                avatar.classList.add("about__avatar--fixed");
            }

            // Scroll zone animation: slide to center and zoom
            if (scrollZone && initialRect) {
                const zoneRect = scrollZone.getBoundingClientRect();
                const totalTravel = zoneRect.height + window.innerHeight;
                const traveled = window.innerHeight - zoneRect.top;
                const progress = Math.min(
                    Math.max(traveled / totalTravel, 0),
                    1,
                );

                const vpWidth = document.documentElement.clientWidth;
                const centerOffset =
                    vpWidth / 2 - (initialRect.left + initialRect.width / 2);
                const topOffset = 0 - initialRect.top;
                const targetScale = Math.max(vpWidth / initialRect.width, 2.5);

                const currentTx = centerOffset * progress;
                const currentTy = topOffset * progress;
                const currentScale = 1 + (targetScale - 1) * progress;

                avatar.style.transform = `translateX(${currentTx}px) translateY(${currentTy}px) scale(${currentScale})`;
                avatar.style.transformOrigin = "top center";
            }
        }

        window.addEventListener("scroll", onScroll);
        document.addEventListener(
            "astro:before-swap",
            () => {
                window.removeEventListener("scroll", onScroll);
            },
            { once: true },
        );
    }

    document.addEventListener("astro:page-load", initVideoOverlays);
    document.addEventListener("astro:page-load", initAvatarSticky);
    initVideoOverlays();
    initAvatarSticky();
</script>
