---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Stefano Gaming">
    <section class="hero">
        <img
            src="/images/name-banner.png"
            alt="Stefano Gaming"
            class="hero__banner"
        />
    </section>

    <section class="games">
        <div class="games__grid">
            <article class="card">
                <img
                    src="/images/games/tales-from-dreadlight-the-morgue.png"
                    alt="Tales From Dreadlight: The Morgue"
                    class="card__image"
                />
                <h2 class="card__title">Tales From Dreadlight: The Morgue</h2>
                <div class="card__video">
                    <iframe
                        src="https://www.youtube.com/embed/uwpV97Vf8S0"
                        title="Tales From Dreadlight: The Morgue Trailer"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen></iframe>
                </div>
                <a
                    href="https://stefano-gaming.itch.io/tales-from-dreadlight-the-morgue"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="card__link"
                >
                    Play on itch.io
                </a>
            </article>

            <article class="card">
                <img
                    src="/images/games/speak-with-screams.png"
                    alt="Speak With Screams"
                    class="card__image"
                />
                <h2 class="card__title">Speak With Screams</h2>
                <div class="card__video">
                    <iframe
                        src="https://www.youtube.com/embed/lJlCHp-Ql00"
                        title="Speak With Screams Trailer"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen></iframe>
                </div>
                <a
                    href="https://stefano-gaming.itch.io/speak-with-screams"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="card__link"
                >
                    Play on itch.io
                </a>
            </article>

            <article class="card">
                <img
                    src="/images/games/acceptance.png"
                    alt="Acceptance"
                    class="card__image"
                />
                <h2 class="card__title">Acceptance</h2>
                <div class="card__video">
                    <iframe
                        src="https://www.youtube.com/embed/I1A3MlH_v3U"
                        title="Acceptance Trailer"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen></iframe>
                </div>
                <a
                    href="https://stefano-gaming.itch.io/acceptance"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="card__link"
                >
                    Play on itch.io
                </a>
            </article>
        </div>
    </section>
</Layout>

<style>
    :root {
        --bg: #000000;
        --card-bg: #0a0a0a;
        --text: #ffffff;
        --muted: #818181;
        --primary: #3374ff;
        --border: #222222;
    }

    .hero {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem 1rem;
    }

    .hero__banner {
        max-width: 100%;
        height: auto;
    }

    .games {
        padding: 2rem 1rem;
    }

    .games__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    @media (min-width: 768px) {
        .games__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .games__grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .card {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.2s ease;
    }

    .card:hover {
        border-color: var(--primary);
    }

    .card__image {
        width: 100%;
        max-height: 200px;
        object-fit: cover;
        display: block;
    }

    .card__title {
        color: var(--text);
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1rem 1rem 0.75rem;
    }

    .card__video {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%; /* 16:9 aspect ratio */
        margin: 0 0 1rem;
    }

    .card__video iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    .card__link {
        display: inline-block;
        margin: 0 1rem 1rem;
        padding: 0.6rem 1.2rem;
        background-color: var(--primary);
        color: var(--text);
        text-decoration: none;
        border-radius: 4px;
        font-weight: 500;
        text-align: center;
        transition: opacity 0.2s ease;
    }

    .card__link:hover {
        opacity: 0.85;
    }
</style>
