---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const featuredGames = await getCollection(
    "games",
    (game) => game.data.featured,
);
---

<Layout title="Stefano Gaming" bodyClass="has-bg">
    <section class="hero">
        <img
            src="/images/name-banner.png"
            alt="Stefano Gaming"
            class="hero__banner"
        />
    </section>

    <section class="games">
        <div class="games__grid">
            {
                featuredGames.map((game) => (
                    <article
                        class="card"
                        data-has-video={!!game.data.youtubeId}
                    >
                        <div class="card__media">
                            <img
                                src={game.data.image}
                                alt={game.data.title}
                                class="card__media-img"
                            />
                            {game.data.youtubeId && (
                                <div
                                    class="card__media-video"
                                    data-src={`https://www.youtube.com/embed/${game.data.youtubeId}?autoplay=1&mute=1`}
                                >
                                    <iframe
                                        title={`${game.data.title} Trailer`}
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen
                                    />
                                </div>
                            )}
                        </div>
                        <h2 class="card__title">{game.data.title}</h2>
                        <a
                            href={game.data.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="card__link"
                        >
                            Play on itch.io
                        </a>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="about">
        <div class="about__container">
            <img src="/images/avatar.png" alt="Stefano" class="about__avatar" />
            <div class="about__content">
                <h2 class="about__title">About Me</h2>
                <p class="about__text">
                    Hey, I'm Stefano — an indie game developer, musician, pixel
                    artist, voice actor, and sound effects designer. I build
                    games using GDevelop and make all my own art, music, and
                    sounds from scratch.
                </p>
                <p class="about__text">
                    You can play my non-Steam games for free right here on my
                    website. My music is available on YouTube, and you can find
                    me on itch.io, Steam, Twitch, and more. Thanks for stopping
                    by!
                </p>
            </div>
        </div>
    </section>

    <section class="callout">
        <div class="callout__container">
            <h2 class="callout__title">Want to see more?</h2>
            <p class="callout__text">
                Check out the full collection of games I've made.
            </p>
            <a href="/games" class="callout__button">Browse All Games</a>
        </div>
    </section>
</Layout>

<style is:global>
    body.has-bg {
        background-image: url("/images/background.jpg");
        background-size: cover;
        background-position: 50% 50%;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    body.has-bg::before {
        content: "";
        position: fixed;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.3) 0%,
            rgba(0, 0, 0, 0.6) 100%
        );
        z-index: 0;
        pointer-events: none;
    }

    body.has-bg main {
        position: relative;
        z-index: 1;
    }
</style>

<style>
    :root {
        --bg: #000000;
        --card-bg: #0a0a0a;
        --text: #ffffff;
        --muted: #818181;
        --primary: #fe2c00;
        --border: #222222;
    }

    .hero {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 4rem 1rem 3rem;
    }

    .hero__banner {
        max-width: 100%;
        height: auto;
    }

    .about {
        padding: 3rem 1.5rem 0;
    }

    .about__container {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .about__avatar {
        width: 250px;
        height: auto;
        object-fit: cover;
        flex-shrink: 0;
        order: 2;
        transition: none;
    }

    .about__avatar--fixed {
        position: fixed;
        z-index: 10;
    }

    .about__title {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 1rem;
        color: var(--text);
    }

    .about__text {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.7;
        margin: 0 0 0.75rem;
    }

    .about__text:last-child {
        margin-bottom: 0;
    }

    @media (max-width: 640px) {
        .about__container {
            flex-direction: column;
            text-align: center;
        }

        .about__avatar {
            width: 120px;
            height: 120px;
        }
    }

    .callout {
        padding: 3rem 1.5rem;
        text-align: center;
    }

    .callout__container {
        max-width: 600px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .callout__title {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 0.75rem;
        color: var(--text);
    }

    .callout__text {
        color: var(--muted);
        font-size: 1rem;
        margin: 0 0 1.5rem;
        line-height: 1.6;
    }

    .callout__button {
        display: inline-block;
        padding: 0.75rem 2rem;
        background-color: var(--primary);
        color: var(--text);
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 1rem;
        transition: opacity 0.2s ease;
    }

    .callout__button:hover {
        opacity: 0.85;
    }

    .games {
        padding: 2rem 0;
    }

    .games__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .games__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .games__grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .card {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.2s ease;
    }

    .card:hover {
        border-color: var(--primary);
    }

    .card__media {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
    }

    .card__media-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity 0.3s ease;
    }

    .card__media-video {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .card__media-video iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    .card[data-has-video="true"]:hover .card__media-img {
        opacity: 0;
    }

    .card[data-has-video="true"]:hover .card__media-video {
        opacity: 1;
        pointer-events: auto;
    }

    .card__title {
        color: var(--text);
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1rem 1rem 0.75rem;
    }

    .card__link {
        display: inline-block;
        margin: 0 1rem 1rem;
        padding: 0.6rem 1.2rem;
        background-color: var(--primary);
        color: var(--text);
        text-decoration: none;
        border-radius: 4px;
        font-weight: 500;
        text-align: center;
        transition: opacity 0.2s ease;
    }

    .card__link:hover {
        opacity: 0.85;
    }
</style>

<script>
    document
        .querySelectorAll(".card[data-has-video='true']")
        .forEach((card) => {
            const videoDiv = card.querySelector(".card__media-video");
            if (!videoDiv) return;
            const iframe = videoDiv.querySelector("iframe");
            if (!iframe) return;

            card.addEventListener("mouseenter", () => {
                iframe.src = videoDiv.dataset.src || "";
            });

            card.addEventListener("mouseleave", () => {
                iframe.src = "";
            });
        });

    const avatar = document.querySelector(".about__avatar");
    const aboutSection = document.querySelector(".about");

    if (avatar && aboutSection) {
        const placeholder = document.createElement("div");

        window.addEventListener("scroll", () => {
            const rect = aboutSection.getBoundingClientRect();
            if (rect.bottom < window.innerHeight) {
                if (!avatar.classList.contains("about__avatar--fixed")) {
                    const avatarRect = avatar.getBoundingClientRect();
                    placeholder.style.width = avatarRect.width + "px";
                    placeholder.style.height = avatarRect.height + "px";
                    placeholder.style.order = "2";
                    placeholder.style.flexShrink = "0";
                    avatar.parentNode.insertBefore(placeholder, avatar);
                    avatar.style.top = avatarRect.top + "px";
                    avatar.style.left = avatarRect.left + "px";
                    avatar.classList.add("about__avatar--fixed");
                }
            } else {
                if (avatar.classList.contains("about__avatar--fixed")) {
                    avatar.classList.remove("about__avatar--fixed");
                    avatar.style.top = "";
                    avatar.style.left = "";
                    placeholder.remove();
                }
            }
        });
    }
</script>
