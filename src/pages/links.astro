---
import Layout from "../layouts/Layout.astro";

const links = [
    {
        name: "YouTube",
        url: "https://www.youtube.com/@Stefano_Gaming",
        color: "#FF0000",
    },
    {
        name: "Twitch",
        url: "https://www.twitch.tv/stefano_gamingtv",
        color: "#9146FF",
    },
    {
        name: "Twitter / X",
        url: "https://x.com/StefanoGaming53",
        color: "#FFFFFF",
    },
    {
        name: "Itch.io",
        url: "https://stefano-gaming.itch.io",
        color: "#FA5C5C",
    },
    {
        name: "Steam",
        url: "https://steamcommunity.com/profiles/76561198966597091/",
        color: "#66C0F4",
    },
    {
        name: "GDevelop",
        url: "https://gd.games/Stefano_Gaming",
        color: "#3E9A3E",
    },
    {
        name: "Spotify",
        url: "https://open.spotify.com/artist/52IwESXoFNackotDmAFHSG?si=N-vuK82TSFC3tooJT_lhaA",
        color: "#1DB954",
    },
];

function getFaviconUrl(pageUrl: string, size = 64): string {
    const origin = new URL(pageUrl).origin;
    return `https://t0.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=${encodeURIComponent(origin)}&size=${size}`;
}
---

<Layout title="Links | Stefano Gaming">
    <div class="links-page">
        <div class="links-header">
            <img
                src="/images/logo.png"
                alt="Stefano Gaming"
                class="links-avatar"
                width="80"
                height="80"
            />
            <h1 class="links-title">Stefano Gaming</h1>
            <p class="links-subtitle">Find me everywhere</p>
        </div>

        <nav class="links-list">
            {
                links.map((link) => (
                    <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="link-tile"
                        style={`--tile-color: ${link.color}`}
                    >
                        <span class="link-tile__icon">
                            <img
                                src={getFaviconUrl(link.url)}
                                alt={link.name}
                                width="24"
                                height="24"
                                loading="lazy"
                            />
                        </span>
                        <span class="link-tile__name">{link.name}</span>
                        <svg
                            class="link-tile__arrow"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            width="18"
                            height="18"
                        >
                            <path d="M7 17L17 7M17 7H7M17 7v10" />
                        </svg>
                    </a>
                ))
            }
        </nav>
    </div>
</Layout>

<style>
    .links-page {
        max-width: 480px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* ── Header ── */
    .links-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 2.5rem;
    }

    .links-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: contain;
        margin-bottom: 1rem;
        border: 2px solid #222;
    }

    .links-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        margin: 0 0 0.25rem;
        letter-spacing: -0.01em;
    }

    .links-subtitle {
        font-size: 0.9rem;
        color: #818181;
        margin: 0;
    }

    /* ── Link List ── */
    .links-list {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        width: 100%;
    }

    /* ── Link Tile ── */
    .link-tile {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        padding: 0.875rem 1.125rem;
        background-color: #0a0a0a;
        border: 1px solid #1a1a1a;
        border-radius: 12px;
        text-decoration: none;
        color: #fff;
        transition:
            border-color 0.2s ease,
            background-color 0.2s ease,
            transform 0.15s ease;
    }

    .link-tile:hover {
        border-color: var(--tile-color, #fe2c00);
        background-color: #111;
        transform: translateY(-2px);
    }

    .link-tile:active {
        transform: translateY(0);
    }

    /* ── Icon ── */
    .link-tile__icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background-color: rgba(255, 255, 255, 0.05);
        transition: background-color 0.2s ease;
    }

    .link-tile:hover .link-tile__icon {
        background-color: color-mix(
            in srgb,
            var(--tile-color, #fff) 12%,
            transparent
        );
    }

    .link-tile__icon img {
        display: block;
        width: 24px;
        height: 24px;
        object-fit: contain;
    }

    /* ── Name ── */
    .link-tile__name {
        flex: 1;
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.3;
    }

    /* ── Arrow ── */
    .link-tile__arrow {
        flex-shrink: 0;
        opacity: 0;
        color: var(--tile-color, #fe2c00);
        transform: translate(-4px, 4px);
        transition:
            opacity 0.2s ease,
            transform 0.2s ease;
    }

    .link-tile:hover .link-tile__arrow {
        opacity: 1;
        transform: translate(0, 0);
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
        .links-page {
            padding: 1.5rem 1.25rem 2.5rem;
        }

        .links-avatar {
            width: 64px;
            height: 64px;
        }

        .links-title {
            font-size: 1.3rem;
        }

        .link-tile {
            padding: 0.75rem 1rem;
        }

        .link-tile__icon {
            width: 36px;
            height: 36px;
        }

        .link-tile__icon img {
            width: 20px;
            height: 20px;
        }

        .link-tile__name {
            font-size: 0.95rem;
        }
    }
</style>
