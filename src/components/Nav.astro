---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="nav">
  <div class="nav-brand">
    <a href="/">Stefano</a>
  </div>
  <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
    <span class="hamburger"></span>
  </button>
  <ul class="nav-links">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class:list={["nav-link", { active: currentPath === link.href }]}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const links = document.querySelector(".nav-links");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    links?.classList.toggle("open");
  });
</script>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background-color: var(--nav-bg, #0f0f0f);
    border-bottom: 1px solid var(--border-color, #222);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-brand a {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary, #f0f0f0);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-brand a:hover {
    color: var(--accent, #646cff);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: var(--text-secondary, #a0a0a0);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--accent, #646cff);
    transition: width 0.25s ease;
  }

  .nav-link:hover {
    color: var(--text-primary, #f0f0f0);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--accent, #646cff);
  }

  .nav-link.active::after {
    width: 100%;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--text-primary, #f0f0f0);
    position: relative;
    transition: background-color 0.2s ease;
  }

  .hamburger::before,
  .hamburger::after {
    content: "";
    position: absolute;
    width: 24px;
    height: 2px;
    background-color: var(--text-primary, #f0f0f0);
    transition: transform 0.2s ease;
  }

  .hamburger::before {
    top: -7px;
  }

  .hamburger::after {
    top: 7px;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: block;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background-color: var(--nav-bg, #0f0f0f);
      border-bottom: 1px solid var(--border-color, #222);
      padding: 1rem 2rem;
      gap: 1rem;
    }

    .nav-links.open {
      display: flex;
    }
  }
</style>
